[Unit]
Description=PDF Tools Web Service
After=network.target

[Service]
Type=simple
User=pdf-tools
Group=pdf-tools
WorkingDirectory=/root/agents/pdf_tools
ExecStart=/root/miniconda3/envs/p1/bin/uvicorn main:app --host 0.0.0.0 --port 1234
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/root/agents/pdf_tools/uploads /root/agents/pdf_tools/outputs /root/agents/pdf_tools/logs

[Install]
WantedBy=multi-user.target
